{
  "name": "Barter-Based-Trading-Platform-tests",
  "version": "1.0.0",
  "description": "Smart contract tests for Barter Trading Platform with Trade Analytics",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:report": "vitest run -- --coverage --costs",
    "test:watch": "chokidar \"tests/**/*.ts\" \"contracts/**/*.clar\" -c \"npm run test:report\"",
    "lint": "clarinet check",
    "typecheck": "tsc --noEmit"
  },
  "author": "ozeyeyinoah <ozeyeyinoah@gmail.com>",
  "license": "ISC",
  "dependencies": {
    "@hirosystems/clarinet-sdk": "^3.0.0",
    "@stacks/transactions": "^7.0.5",
    "chokidar-cli": "^3.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.0",
    "vitest-environment-clarinet": "^2.3.0"
  }
}
